# Next.js Runtime Environment
NODE_ENV=production
NEXT_PUBLIC_APP_URL=https://gloriousedubd.com

# Backend API Orchestration (NestJS Services)
NEXT_PUBLIC_API_URL=https://api.gloriousedubd.com/v1

# Security and Analytics
NEXT_PUBLIC_CLOUDFLARE_ANALYTICS_ID=your_cloudflare_id
NEXT_PUBLIC_GOOGLE_ANALYTICS_ID=your_google_id

# CDN Settings (Images & Static Resources)
NEXT_PUBLIC_CDN_URL=https://cdn.gloriousedubd.com